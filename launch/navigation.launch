<launch>

  <!-- ##### SETTINGS { ##### -->

  <!-- often changed arguments -->
  <arg name="gazebo_world_name" default="maze" /> <!-- empty, empty_garden, cylinder_garden, maze, tiles, maze_tiles -->
  <arg name="joy_operation" default="false" />
  <arg name="local_planner" default="mppi_h" /> <!-- mppi_3d_a, mppi_3d_b, mppi_4d, mppi_h, mppi_hc, mppi_ilc, mppi_ilc_prior, mppi_tf -->
  <arg name="ilc_config" default="$(find mppi_ilc)/config/mppi_ilc.yaml" />
  <arg name="mppi_tf_sampling_mode" default="velocity" /> <!-- force, velocity (for mppi_tf only) -->
  <arg name="wheel_friction" default="0.8" />
  <arg name="use_amcl" default="true" />

  <!-- arguments -->
  <arg name="workspace" default="$(env HOME)/planner_code/mppi_swerve_drive_ros" />
  <arg name="rvizconfig" default="$(arg workspace)/data/rviz/navigation.rviz" />
  <arg name="open_rviz" default="true"/>
  <rosparam param="/use_sim_time">true</rosparam> <!-- set use_sim_time true to syncronize time with gazebo -->
  <arg name="scan_topic"     default="/laser_link/scan"/>
  <arg name="cmd_vel_topic"  default="/cmd_vel"/>
  <arg name="odom_topic"     default="/groundtruth_odom"/>
  <arg name="set_base_frame" default="base_link"/>
  <arg name="set_odom_frame" default="odom"/>
  <arg name="set_map_frame"  default="map"/>
  <arg name="initial_pose_x" default="0.0"/>
  <arg name="initial_pose_y" default="0.0"/>
  <arg name="initial_pose_yaw" default="0.0"/>
  <rosparam param="/use_sim_time">true</rosparam> <!-- set use_sim_time true to syncronize time with gazebo -->

    <!-- Optional: log MPPIEval topics to CSV (Excel-friendly) -->
    <arg name="enable_eval_logging" default="false" />
    <arg name="eval_log_dir" default="$(env HOME)/log" />
    <arg name="eval_log_tag" default="$(arg local_planner)" />

    <!-- MPPI-HC quick tuning / ablation (only used when local_planner==mppi_hc) -->
    <arg name="hc_enable_compensation" default="true" />
    <arg name="hc_compensation_gain" default="0.8" />
    <arg name="hc_slip_learning_rate" default="0.01" />
    <arg name="hc_slip_factor_max" default="0.3" />
    <arg name="hc_feedback_k_lateral" default="1.5" />
    <arg name="hc_feedback_k_heading" default="0.5" />
    <arg name="hc_feedback_k_integral" default="0.2" />

  <!-- ##### } SETTINGS ##### -->


  <!-- ##### COMMON NODES { ##### -->

  <!-- launch gazebo world -->
  <include file="$(arg workspace)/launch/gazebo_world.launch">
    <arg name="gazebo_world_name" value="$(arg gazebo_world_name)" />
    <arg name="use_joystick" value="$(arg joy_operation)" />
    <arg name="use_vel_driver" value="false" />
    <arg name="open_rviz" value="false" />
    <arg name="wheel_friction" value="$(arg wheel_friction)" />
  </include>

  <!-- map server -->
  <node pkg="map_server" type="map_server" name="map_server" args="$(arg workspace)/data/map/$(arg gazebo_world_name)/map.yaml" />

  <!-- 3d map visualizer -->
  <include file="$(find map_visualizer)/launch/map_visualizer.launch">
    <arg name="map_name" value="$(arg gazebo_world_name)" />
  </include>

  <!-- amcl -->
  <group if="$(arg use_amcl)">
    <node pkg="amcl" type="amcl" name="amcl">
        <param name="initial_pose_x"            value="$(arg initial_pose_x)"/>
        <param name="initial_pose_y"            value="$(arg initial_pose_y)"/>
        <param name="initial_pose_a"            value="$(arg initial_pose_yaw)"/>
        <remap from="scan"                      to="$(arg scan_topic)"/>
        <rosparam file="$(arg workspace)/config/amcl.yaml" command="load" />
    </node>
  </group>

  <!-- fake localization (static tf map->odom) -->
  <group unless="$(arg use_amcl)">
    <node pkg="tf2_ros" type="static_transform_publisher" name="map_to_odom" args="0 0 0 0 0 0 map odom" />
  </group>

  <!-- rviz -->
  <group if="$(arg open_rviz)"> 
    <node name="rviz" pkg="rviz" type="rviz" args="-d $(arg rvizconfig)" required="true" />
  </group>

  <!-- ##### } COMMON NODES ##### -->


    <!-- ##### OPTIONAL LOGGING { ##### -->

    <!-- For paper plots we log per-lap tracking metrics into ONE CSV per run.
             Note: mppi_ilc_prior already writes its own single per-lap CSV (with ILC-specific metrics),
             so we don't start the generic paper logger for that planner to keep "one algorithm -> one CSV". -->
    <group if="$(eval enable_eval_logging and local_planner!='mppi_ilc_prior')">
        <node pkg="mppi_paper_logger" type="mppi_paper_logger.py" name="mppi_paper_logger" output="screen">
            <param name="log_dir" value="$(arg eval_log_dir)" />
            <param name="tag" value="$(arg eval_log_tag)" />
            <param name="odom_topic" value="$(arg odom_topic)" />
            <param name="reference_path_topic" value="/reference_path_full" />
            <param name="reset_on_path_update" value="false" />
            <param name="corner_curvature_threshold" value="0.10" />
            <param name="wrap_s_margin" value="0.5" />
            <param name="closed_path_threshold" value="0.6" />
        </node>
    </group>

    <!-- ##### } OPTIONAL LOGGING ##### -->


  <!-- ##### LAUNCH SELECTED LOCAL PLANNER { ##### -->

  <!-- MPPI-3D (a) (exploring 3 dimensional space: vx, vy, omega) -->
  <group if="$(eval local_planner=='mppi_3d_a')">
      <include file="$(find mppi_3d)/launch/mppi_3d_a.launch" />

      <!-- reference_costmap_generator -->
      <include file="$(find reference_costmap_generator)/launch/reference_costmap_generator.launch" />

      <!-- launch global planner -->
      <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
          <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS" />
          <rosparam file="$(arg workspace)/config/base_local_planner.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_common_global.yaml" command="load" ns="global_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_common_local.yaml" command="load" ns="local_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_local.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_global.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/move_base.yaml" command="load" />
          <remap from="cmd_vel" to="/no_use/cmd_vel"/>
          <remap from="odom" to="$(arg odom_topic)"/>
          <remap from="scan" to="$(arg scan_topic)"/>
      </node>

      <!-- launch vel_driver to operate 4WIDS vehicle with /cmd_vel-->
      <include file="$(find vel_driver)/launch/vel_driver.launch" />
  </group>

  <!-- MPPI-3D (b) (exploring 3 dimensional space: vx, vy, omega) -->
  <group if="$(eval local_planner=='mppi_3d_b')">
      <include file="$(find mppi_3d)/launch/mppi_3d_b.launch" />

      <!-- reference_costmap_generator -->
      <include file="$(find reference_costmap_generator)/launch/reference_costmap_generator.launch" />

      <!-- launch global planner -->
      <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
          <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS" />
          <rosparam file="$(arg workspace)/config/base_local_planner.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_common_global.yaml" command="load" ns="global_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_common_local.yaml" command="load" ns="local_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_local.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_global.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/move_base.yaml" command="load" />
          <remap from="cmd_vel" to="/no_use/cmd_vel"/>
          <remap from="odom" to="$(arg odom_topic)"/>
          <remap from="scan" to="$(arg scan_topic)"/>
      </node>

      <!-- launch vel_driver to operate 4WIDS vehicle with /cmd_vel-->
      <include file="$(find vel_driver)/launch/vel_driver.launch" />
  </group>

  <!-- MPPI-4D (exploring 4 dimensional space) -->
  <group if="$(eval local_planner=='mppi_4d')">
      <include file="$(find mppi_4d)/launch/mppi_4d.launch" />

      <!-- reference_costmap_generator -->
      <include file="$(find reference_costmap_generator)/launch/reference_costmap_generator.launch" />

      <!-- launch global planner -->
      <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
          <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS" />
          <rosparam file="$(arg workspace)/config/base_local_planner.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_common_global.yaml" command="load" ns="global_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_common_local.yaml" command="load" ns="local_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_local.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_global.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/move_base.yaml" command="load" />
          <remap from="cmd_vel" to="/no_use/cmd_vel"/>
          <remap from="odom" to="$(arg odom_topic)"/>
          <remap from="scan" to="$(arg scan_topic)"/>
      </node>

      <!-- launch vel_driver to operate 4WIDS vehicle with /cmd_vel-->
      <include file="$(find vel_driver)/launch/vel_driver.launch" />
  </group>

  <!-- MPPI-H (switching MPPI-3D and MPPI-4D in real-time) -->
  <group if="$(eval local_planner=='mppi_h')">
      <include file="$(find mppi_h)/launch/mppi_h.launch" />

      <!-- reference_costmap_generator -->
      <include file="$(find reference_costmap_generator)/launch/reference_costmap_generator.launch" />

      <!-- launch global planner -->
      <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
          <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS" />
          <rosparam file="$(arg workspace)/config/base_local_planner.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_common_global.yaml" command="load" ns="global_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_common_local.yaml" command="load" ns="local_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_local.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_global.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/move_base.yaml" command="load" />
          <remap from="cmd_vel" to="/no_use/cmd_vel"/>
          <remap from="odom" to="$(arg odom_topic)"/>
          <remap from="scan" to="$(arg scan_topic)"/>
      </node>

      <!-- launch vel_driver to operate 4WIDS vehicle with /cmd_vel-->
      <include file="$(find vel_driver)/launch/vel_driver.launch" />
  </group>

  <!-- MPPI-HC (Hierarchical Compensated MPPI with slip estimation) -->
  <group if="$(eval local_planner=='mppi_hc')">
      <include file="$(find mppi_hc)/launch/mppi_hc.launch">
          <arg name="enable_compensation" value="$(arg hc_enable_compensation)" />
          <arg name="compensation_gain" value="$(arg hc_compensation_gain)" />
          <arg name="learning_rate" value="$(arg hc_slip_learning_rate)" />
          <arg name="slip_factor_max" value="$(arg hc_slip_factor_max)" />
          <arg name="feedback_k_lateral" value="$(arg hc_feedback_k_lateral)" />
          <arg name="feedback_k_heading" value="$(arg hc_feedback_k_heading)" />
          <arg name="feedback_k_integral" value="$(arg hc_feedback_k_integral)" />
      </include>

      <!-- reference_costmap_generator -->
      <include file="$(find reference_costmap_generator)/launch/reference_costmap_generator.launch" />

      <!-- launch global planner -->
      <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
          <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS" />
          <rosparam file="$(arg workspace)/config/base_local_planner.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_common_global.yaml" command="load" ns="global_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_common_local.yaml" command="load" ns="local_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_local.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_global.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/move_base.yaml" command="load" />
          <remap from="cmd_vel" to="/no_use/cmd_vel"/>
          <remap from="odom" to="$(arg odom_topic)"/>
          <remap from="scan" to="$(arg scan_topic)"/>
      </node>

      <!-- launch vel_driver to operate 4WIDS vehicle with /cmd_vel-->
      <include file="$(find vel_driver)/launch/vel_driver.launch" />
  </group>

  <!-- MPPI-ILC (MPPI-HC + Iterative Learning Control feedforward) -->
  <group if="$(eval local_planner=='mppi_ilc')">
      <include file="$(find mppi_ilc)/launch/mppi_ilc.launch">
          <arg name="config_file" value="$(arg ilc_config)" />
      </include>

      <!-- reference_costmap_generator -->
      <include file="$(find reference_costmap_generator)/launch/reference_costmap_generator.launch" />

      <!-- launch global planner -->
      <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
          <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS" />
          <rosparam file="$(arg workspace)/config/base_local_planner.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_common_global.yaml" command="load" ns="global_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_common_local.yaml" command="load" ns="local_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_local.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_global.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/move_base.yaml" command="load" />
          <remap from="cmd_vel" to="/no_use/cmd_vel"/>
          <remap from="odom" to="$(arg odom_topic)"/>
          <remap from="scan" to="$(arg scan_topic)"/>
      </node>

      <!-- launch vel_driver to operate 4WIDS vehicle with /cmd_vel-->
      <include file="$(find vel_driver)/launch/vel_driver.launch" />
  </group>

  <!-- MPPI-ILC-PRIOR (MPPI-HC + ILC used as MPPI control prior) -->
  <group if="$(eval local_planner=='mppi_ilc_prior')">
      <include file="$(find mppi_ilc_prior)/launch/mppi_ilc_prior.launch">
          <arg name="config" value="$(arg ilc_config)" />
          <arg name="odom_topic" value="$(arg odom_topic)" />
          <arg name="cmd_vel_topic" value="$(arg cmd_vel_topic)" />
          <arg name="reference_path_topic" value="/reference_path_full" />
          <arg name="collision_costmap_topic" value="/move_base/local_costmap/costmap" />
          <arg name="distance_error_map_topic" value="/distance_error_map" />
          <arg name="reference_yaw_map_topic" value="/ref_yaw_map" />
      </include>

      <!-- reference_costmap_generator -->
      <include file="$(find reference_costmap_generator)/launch/reference_costmap_generator.launch">
          <arg name="ref_path_topic" value="/reference_path_full" />
      </include>

      <!-- launch global planner -->
      <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
          <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS" />
          <rosparam file="$(arg workspace)/config/base_local_planner.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_common_global.yaml" command="load" ns="global_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_common_local.yaml" command="load" ns="local_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_local.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_global.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/move_base.yaml" command="load" />
          <remap from="cmd_vel" to="/no_use/cmd_vel"/>
          <remap from="odom" to="$(arg odom_topic)"/>
          <remap from="scan" to="$(arg scan_topic)"/>
      </node>

      <!-- launch vel_driver to operate 4WIDS vehicle with /cmd_vel-->
      <include file="$(find vel_driver)/launch/vel_driver.launch" />
  </group>

  <!-- MPPI-TF (TireForce-based MPPI with Pacejka tire model and online estimation) -->
  <group if="$(eval local_planner=='mppi_tf')">
      <include file="$(find mppi_tf)/launch/mppi_tf.launch">
          <arg name="sampling_mode" value="$(arg mppi_tf_sampling_mode)" />
      </include>

      <!-- reference_costmap_generator -->
      <include file="$(find reference_costmap_generator)/launch/reference_costmap_generator.launch" />

      <!-- launch global planner -->
      <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
          <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS" />
          <rosparam file="$(arg workspace)/config/base_local_planner.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_common_global.yaml" command="load" ns="global_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_common_local.yaml" command="load" ns="local_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_local.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_global.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/move_base.yaml" command="load" />
          <remap from="cmd_vel" to="/no_use/cmd_vel"/>
          <remap from="odom" to="$(arg odom_topic)"/>
          <remap from="scan" to="$(arg scan_topic)"/>
      </node>

      <!-- launch vel_driver to operate 4WIDS vehicle with /cmd_vel-->
      <include file="$(find vel_driver)/launch/vel_driver.launch" />
  </group>

  <!-- (not supported) move_base [base local planner] -->
  <group if="$(eval local_planner=='base')">
      <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
          <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS" />
          <rosparam file="$(arg workspace)/config/base_local_planner.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_common_global.yaml" command="load" ns="global_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_common_local.yaml" command="load" ns="local_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_local.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_global.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/move_base.yaml" command="load" />
          <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
          <remap from="odom" to="$(arg odom_topic)"/>
          <remap from="scan" to="$(arg scan_topic)"/>
      </node>
      <!-- launch vel_driver to operate 4WIDS vehicle with /cmd_vel-->
      <include file="$(find vel_driver)/launch/vel_driver.launch" />
  </group>

  <!-- (not supported) move_base [teb local planner] -->
  <group if="$(eval local_planner=='teb')">
      <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
          <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS" />
          <rosparam file="$(arg workspace)/config/teb_local_planner.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_common_global.yaml" command="load" ns="global_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_common_local.yaml" command="load" ns="local_costmap" />
          <rosparam file="$(arg workspace)/config/costmap_local.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/costmap_global.yaml" command="load" />
          <rosparam file="$(arg workspace)/config/move_base.yaml" command="load" />
          <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
          <remap from="odom" to="$(arg odom_topic)"/>
          <remap from="scan" to="$(arg scan_topic)"/>
      </node>
      <!-- launch vel_driver to operate 4WIDS vehicle with /cmd_vel-->
      <include file="$(find vel_driver)/launch/vel_driver.launch" />
  </group>

  <!-- ##### } LAUNCH SELECTED LOCAL PLANNER ##### -->


</launch>